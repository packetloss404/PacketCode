{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri2-schema/main/tauri.conf.json.schema",
  "productName": "PacketCode",
  "version": "0.1.0",
  "identifier": "com.packetcode.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PacketCode",
        "width": 1400,
        "height": 900,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
